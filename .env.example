# ──────────────────────────────────────────────────────────────────────────────
# Aqila IMS — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
#
# Production checklist & vault guidance:
#   docs/secrets-and-config.md
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (default password matches docker/docker-compose.yml)
DATABASE_URL="postgresql://aqila_user:aqila_dev_secret@localhost:15432/aqila_ims"
#
# Optional: direct Postgres URL for `prisma migrate` / CLI when DATABASE_URL is a transaction pooler.
# See docs/database-connection-pooling.md
# DATABASE_DIRECT_URL="postgresql://aqila_user:aqila_dev_secret@localhost:15432/aqila_ims"
#
# Optional: pg pool sizing per Node process (defaults: max 10, idle 30s, connect timeout 10s)
# DATABASE_POOL_MAX="10"
# DATABASE_POOL_IDLE_MS="30000"
# DATABASE_POOL_CONN_TIMEOUT_MS="10000"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32 (minimum 32 characters in production)
AUTH_SECRET="your_auth_secret_here"

# App URL (used for OAuth callbacks and email links)
NEXTAUTH_URL="http://localhost:3010"

# Optional: canonical public URL for invites / absolute links (falls back to NEXTAUTH_URL)
# AUTH_URL="https://ims.example.com"

# ── Email (optional — PO notifications, password reset, invitations) ─────────
# SMTP settings for Nodemailer — SPF/DKIM/DMARC for your From domain:
#   docs/email-dns-authentication.md
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@aqila.no"
SMTP_PASS="your_smtp_password"
SMTP_FROM="Aqila IMS <noreply@aqila.no>"

# ── Scheduled jobs ────────────────────────────────────────────────────────────
# Bearer secret for GET /api/cron/digest-email (digest + approval escalation).
# When non-empty in production: minimum 24 characters (enforced at startup).
# Example:
#   curl -H "Authorization: Bearer $CRON_SECRET" https://your-host/api/cron/digest-email
CRON_SECRET=""
#
# Optional: restrict callers by observed client IP (first x-forwarded-for hop or x-real-ip).
# Comma-separated exact IPs — only enable if your reverse proxy sets these headers honestly.
# CRON_ALLOWED_IPS="203.0.113.5,198.51.100.2"

# ── Distributed auth rate limits (optional — multi-instance) ────────────────
# When BOTH are set, auth/login/forgot/invite limits use Upstash Redis instead of
# process-local memory. See src/lib/auth-rate-limit-backend.ts + docs/secrets-and-config.md
# UPSTASH_REDIS_REST_URL="https://…"
# UPSTASH_REDIS_REST_TOKEN="…"

# ── OpenTelemetry traces (optional Node exporter) ───────────────────────────
# OTEL_ENABLED="true"
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318/v1/traces"
# Production: https://…/v1/traces on your collector (required when OTEL_ENABLED=true + NODE_ENV=production).
# OTEL_EXPORTER_OTLP_HEADERS="Authorization=Bearer%20…"
# OTEL_SERVICE_NAME="aqila-ims"

# ── Application ───────────────────────────────────────────────────────────────
# Set to "production" in prod
NODE_ENV="development"

# Optional: Log level (trace | debug | info | warn | error)
LOG_LEVEL="info"

# Optional: deployment revision on GET /api/health (git tag or short SHA)
# APP_VERSION="v1.0.0"

# ── Playwright UI smoke (development/staging only) ────────────────────────────
# PLAYWRIGHT_BASE_URL="http://localhost:3010"
# PLAYWRIGHT_RUN="1"
